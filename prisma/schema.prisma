// Prisma schema for Finnix Film inout (income/expense) webapp.
// Mirrors the data model implied by reference.html plus the multi-user
// / audit / month-lock requirements discussed in the Gemini chat.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  STAFF
}

enum EntryType {
  INCOME
  EXPENSE
}

enum FileKind {
  JOB_SHEET        // ใบงาน (income, attached to product section)
  INCOME_PROOF     // หลักฐานการรับเงิน (income, attached to payment section)
  EXPENSE_RECEIPT  // ใบเสร็จ (expense)
}

/// App user. id matches Supabase auth.users.id (UUID).
///
/// `branchId` is the *preferred default* branch — what pre-fills the new-entry
/// form. The full access list lives in the `branches` join (UserBranch). For
/// STAFF with exactly one branch we point branchId at that one so the form
/// pre-selects; for multi-branch STAFF we leave it null so they must pick
/// explicitly. ADMIN ignores both (sees everything).
model User {
  id          String   @id @db.Uuid
  email       String   @unique
  displayName String
  role        Role     @default(STAFF)
  branchId    String?  @db.Uuid
  branch      Branch?  @relation("UserDefaultBranch", fields: [branchId], references: [id], onDelete: SetNull)
  branches    UserBranch[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entriesCreated Entry[] @relation("EntryCreatedBy")
  entriesUpdated Entry[] @relation("EntryUpdatedBy")
  monthLocks     MonthLock[]

  @@map("users")
}

model Branch {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  defaultForUsers User[]       @relation("UserDefaultBranch")
  userGrants      UserBranch[]
  entries         Entry[]

  @@map("branches")
}

/// Many-to-many grant: a STAFF user may have access to multiple branches.
/// ADMIN doesn't need rows here — they see all branches unconditionally.
/// Cascade-on-delete on both sides so deleting a user or branch cleans up.
model UserBranch {
  userId    String   @db.Uuid
  branchId  String   @db.Uuid
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch    Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@id([userId, branchId])
  @@index([branchId])
  @@map("user_branches")
}

model ExpenseSource {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]

  @@map("expense_sources")
}

/// Admin-managed expense categories (กลุ่มค่าใช้จ่าย) — e.g. "ค่าน้ำมัน",
/// "ค่าวัสดุ", "ค่าอาหาร". Distinct from ExpenseSource (which tracks the
/// wallet/cash drawer the money came from); ExpenseGroup tracks what the
/// money was spent on. STAFF can view the field but only ADMIN can set or
/// change it — enforced both client- and server-side.
model ExpenseGroup {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]

  @@map("expense_groups")
}

/// Admin-managed list of payment methods used on income entries (e.g.
/// "เงินสด", "เงินโอน", "บัตรเครดิต"). Replaces the old PaymentType enum
/// so the shop can add new channels without a code change.
model PaymentMethod {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]

  @@map("payment_methods")
}

/// Admin-managed list of booking channels (จองผ่าน) — e.g. "LINE", "Facebook",
/// "Walk-in". Used on INCOME entries to track how the customer found us.
model BookingChannel {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]

  @@map("booking_channels")
}

/// Admin-managed list of car brands (ยี่ห้อรถ) — e.g. "Toyota", "Honda".
model CarBrand {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]

  @@map("car_brands")
}

/// Admin-managed list of product categories (ชนิดสินค้า) — e.g.
/// "ฟิล์มกรองแสง", "ฟิล์มกันรอย PPF", "เคลือบแก้ว".
model ProductType {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]

  @@map("product_types")
}

/// Admin-managed product catalog (สินค้าที่จอง / สินค้าที่ขาย) — e.g.
/// "3M Crystalline 70% รอบคัน". Shared between the booked-product and
/// sold-product fields so the shop maintains a single SKU list.
model Product {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookedEntries Entry[] @relation("BookedProduct")
  soldEntries   Entry[] @relation("SoldProduct")

  @@map("products")
}

/// Income or expense entry. Income-only fields live alongside expense-only
/// fields and are nullable; the `type` discriminator says which set is in use.
model Entry {
  id       String    @id @default(uuid()) @db.Uuid
  type     EntryType
  branchId String    @db.Uuid
  branch   Branch    @relation(fields: [branchId], references: [id])
  date     DateTime  @db.Date
  /// derived "YYYY-MM" of `date`, materialized for fast month filtering + lock lookup
  yyyyMm   String    @db.Char(7)
  amount   Decimal   @db.Decimal(12, 2)

  // ---- Income-only ----
  custName     String?
  custTel      String?
  license      String?
  bookedPrice  Decimal? @db.Decimal(12, 2)
  soldPrice    Decimal? @db.Decimal(12, 2)
  prodDetail   String?
  otherDetail  String?
  // 5 admin-managed dropdown FKs (formerly free-text columns: bookedVia,
  // carBrand, prodType, bookedProd, soldProd). Each is nullable + SetNull on
  // delete so admins can deactivate/rename without breaking rows. carModel
  // stayed as free text — admins didn't want to maintain a list of every
  // model/color variant.
  bookingChannelId String?         @db.Uuid
  bookingChannel   BookingChannel? @relation(fields: [bookingChannelId], references: [id], onDelete: SetNull)
  carBrandId       String?         @db.Uuid
  carBrand         CarBrand?       @relation(fields: [carBrandId], references: [id], onDelete: SetNull)
  carModel         String?
  productTypeId    String?         @db.Uuid
  productType      ProductType?    @relation(fields: [productTypeId], references: [id], onDelete: SetNull)
  bookedProductId  String?         @db.Uuid
  bookedProduct    Product?        @relation("BookedProduct", fields: [bookedProductId], references: [id], onDelete: SetNull)
  soldProductId    String?         @db.Uuid
  soldProduct      Product?        @relation("SoldProduct", fields: [soldProductId], references: [id], onDelete: SetNull)
  paymentMethodId  String?         @db.Uuid
  paymentMethod    PaymentMethod?  @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)

  // ---- Expense-only ----
  expenseDetail   String?
  expenseSourceId String?        @db.Uuid
  expenseSource   ExpenseSource? @relation(fields: [expenseSourceId], references: [id], onDelete: SetNull)
  // ADMIN-only on writes. SetNull on delete so admins can rename/deactivate
  // an ExpenseGroup without orphaning expense rows.
  expenseGroupId  String?        @db.Uuid
  expenseGroup    ExpenseGroup?  @relation(fields: [expenseGroupId], references: [id], onDelete: SetNull)

  // ---- Audit ----
  createdById String?  @db.Uuid
  createdBy   User?    @relation("EntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedById String?  @db.Uuid
  updatedBy   User?    @relation("EntryUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  files EntryFile[]

  @@index([branchId, yyyyMm])
  @@index([type, yyyyMm])
  @@map("entries")
}

model EntryFile {
  id           String   @id @default(uuid()) @db.Uuid
  entryId      String   @db.Uuid
  entry        Entry    @relation(fields: [entryId], references: [id], onDelete: Cascade)
  kind         FileKind
  storagePath  String   // path within the Supabase Storage bucket
  originalName String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())

  @@index([entryId])
  @@map("entry_files")
}

/// When a yyyyMm is present here, edits/deletes to entries in that month are
/// rejected for everyone except ADMIN (and ADMIN must explicitly unlock first).
model MonthLock {
  yyyyMm     String   @id @db.Char(7)
  lockedById String?  @db.Uuid
  lockedBy   User?    @relation(fields: [lockedById], references: [id], onDelete: SetNull)
  lockedAt   DateTime @default(now())
  note       String?

  @@map("month_locks")
}

/// Generic key/value config. Used for feature flags like
/// `staff_can_edit_others_in_branch` so admins can toggle without redeploy.
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}
