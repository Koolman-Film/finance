# --- Supabase project URL + keys ---
# Cloud: Project Settings → API
# Local: `supabase status` (after `supabase start`)
#
# Newer Supabase CLI/Cloud call these "Publishable" (sb_publishable_*) and
# "Secret" (sb_secret_*); older projects show "anon" and "service_role" (eyJ...).
# Both formats work — paste whichever your project shows into these vars.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=sb_secret_REPLACE_ME

# --- Postgres connection strings ---
# DATABASE_URL is the app-runtime connection (pooled in cloud, direct locally).
# DIRECT_URL is used by Prisma migrations and must be a direct connection.
#
# Cloud example (note ?pgbouncer=true on DATABASE_URL):
#   DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
#   DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
#
# Local (CLI has no pgbouncer — both URLs point at the same direct port):
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
