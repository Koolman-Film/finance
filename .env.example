# Supabase project URL + keys (from Supabase dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection strings (Supabase dashboard → Project Settings → Database → Connection string)
# DATABASE_URL is the pooled (transaction mode, port 6543) connection for app runtime
# DIRECT_URL is the direct (port 5432) connection for migrations
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
